# App URL (defaults to localhost:4200 if not set)
BASE_URL=http://localhost:4200

# Login credentials for test user
TEST_USERNAME=your-email@example.com
TEST_PASSWORD=your-password

# Credentials used for negative login tests
TEST_WRONG_PASSWORD=wrong-password
TEST_WRONG_USERNAME=nobody@example.com

# Site names used in instance tests (must match the site title shown in the UI)
TEST_SITE_NAME_MAIN=My Main Site
TEST_SITE_NAME_SECONDARY=My Secondary Site
TEST_SITE_NAME_DELETED=Deleted Site
